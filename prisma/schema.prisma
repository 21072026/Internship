generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MENTOR
  MENTEE
}

enum MentorshipStatus {
  ACTIVE
  COMPLETED
}

enum InteractionType {
  Meeting
  Feedback
  Email
}

enum PipelineStatus {
  APPLIED_100
  APPROVED_220
  INTERVIEW_250
  INTRODUCTION_270
  INTERNSHIP_STARTING_300
  INTERNSHIP_ONGOING_450
  DROPPED_OUT_460
  INTERNSHIP_COMPLETED_490
  SEEKING_JOB_500
  HIRABLE_600
  HIRED_660
  FOUND_JOB_700
  INTERNSHIP_ELSEWHERE_800
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           Role     @default(MENTEE)
  fullName       String
  phone          String?
  university     String?
  department     String?
  graduationYear Int?
  skills         Json     @default("[]")
  cvUrl          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mentorRelations MentorshipRelation[] @relation("MentorRelations")
  menteeRelations MentorshipRelation[] @relation("MenteeRelations")
}

model Company {
  id           String   @id @default(cuid())
  name         String
  description  String?
  contactEmail String?
  industry     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  needs       CompanyNeed[]
  mentorships MentorshipRelation[]
}

model CompanyNeed {
  id        String @id @default(cuid())
  companyId String
  position  String
  count     Int
  period    String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MentorshipRelation {
  id             String           @id @default(cuid())
  mentorId       String
  menteeId       String
  companyId      String?
  startDate      DateTime         @default(now())
  status         MentorshipStatus @default(ACTIVE)
  pipelineStatus PipelineStatus   @default(APPLIED_100)

  mentor       User             @relation("MentorRelations", fields: [mentorId], references: [id])
  mentee       User             @relation("MenteeRelations", fields: [menteeId], references: [id])
  company      Company?         @relation(fields: [companyId], references: [id])
  interactions InteractionLog[]
}

model InteractionLog {
  id         String          @id @default(cuid())
  relationId String
  date       DateTime
  notes      String
  type       InteractionType

  relation MentorshipRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
}

model InvitationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  role      Role
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}
